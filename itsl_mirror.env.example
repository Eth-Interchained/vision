# itsl_mirror environment — copy to itsl_mirror.env and fill in values
# Used by both the systemd service and direct CLI invocation.

# ITC Core node JSON-RPC
ITC_RPC_URL=http://127.0.0.1:8332
ITC_RPC_USER=your_rpc_user
ITC_RPC_PASS=your_rpc_password
ITC_WALLET_NAME=bulk_payout_wallet

# nedbd instance
NEDB_URL=http://127.0.0.1:7070
NEDBD_TOKEN=
NEDB_DB_NAME=vision

# Daemon poll interval (seconds)
MIRROR_INTERVAL=30
